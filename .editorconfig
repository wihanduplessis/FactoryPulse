# EditorConfig is awesome: https://editorconfig.org
# Top-most EditorConfig file for the FactoryPulse solution.
root = true

##########################################
# All files
##########################################
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

##########################################
# Markdown
##########################################
[*.md]
# Trailing whitespace can be a hard line break in Markdown.
trim_trailing_whitespace = false

##########################################
# Web / config / data files (2-space)
##########################################
[*.{json,jsonc,yml,yaml,js,ts,html,css,scss,xml}]
indent_size = 2

##########################################
# Project & MSBuild files
##########################################
[*.{csproj,props,targets,slnx}]
indent_size = 2

##########################################
# C# files
##########################################
[*.cs]
indent_size = 4

# --- Language conventions -------------------------------------------------

# Prefer file-scoped namespaces (namespace Foo;)
csharp_style_namespace_declarations = file_scoped:warning

# 'this.' qualification — don't require it
dotnet_style_qualification_for_field = false:suggestion
dotnet_style_qualification_for_property = false:suggestion
dotnet_style_qualification_for_method = false:suggestion
dotnet_style_qualification_for_event = false:suggestion

# Language keywords (int, string) over framework types (Int32, String)
dotnet_style_predefined_type_for_locals_parameters_members = true:suggestion
dotnet_style_predefined_type_for_member_access = true:suggestion

# 'var' usage — prefer when the type is apparent
csharp_style_var_for_built_in_types = true:suggestion
csharp_style_var_when_type_is_apparent = true:suggestion
csharp_style_var_elsewhere = false:suggestion

# Modern C# expression preferences
csharp_style_expression_bodied_methods = when_on_single_line:suggestion
csharp_style_expression_bodied_properties = true:suggestion
csharp_prefer_braces = true:suggestion
csharp_style_prefer_switch_expression = true:suggestion
dotnet_style_prefer_conditional_expression_over_return = true:suggestion
dotnet_style_null_propagation = true:suggestion
dotnet_style_coalesce_expression = true:suggestion

# using directives outside the namespace, System first, sorted
csharp_using_directive_placement = outside_namespace:warning
dotnet_sort_system_directives_first = true
dotnet_separate_import_directive_groups = false

# Encourage readonly fields
dotnet_style_readonly_field = true:suggestion

# --- Naming conventions ---------------------------------------------------

# Private/internal instance fields -> _camelCase
dotnet_naming_rule.private_fields_underscore.symbols  = private_fields
dotnet_naming_rule.private_fields_underscore.style    = underscore_camel_case
dotnet_naming_rule.private_fields_underscore.severity = suggestion

dotnet_naming_symbols.private_fields.applicable_kinds           = field
dotnet_naming_symbols.private_fields.applicable_accessibilities = private, internal

dotnet_naming_style.underscore_camel_case.capitalization  = camel_case
dotnet_naming_style.underscore_camel_case.required_prefix = _

# Interfaces -> IPascalCase
dotnet_naming_rule.interfaces_start_with_i.symbols  = interfaces
dotnet_naming_rule.interfaces_start_with_i.style    = i_pascal_case
dotnet_naming_rule.interfaces_start_with_i.severity = warning

dotnet_naming_symbols.interfaces.applicable_kinds = interface

dotnet_naming_style.i_pascal_case.capitalization  = pascal_case
dotnet_naming_style.i_pascal_case.required_prefix = I

# Types & public members -> PascalCase
dotnet_naming_rule.types_pascal_case.symbols  = types_and_members
dotnet_naming_rule.types_pascal_case.style    = pascal_case
dotnet_naming_rule.types_pascal_case.severity = suggestion

dotnet_naming_symbols.types_and_members.applicable_kinds = class, struct, enum, property, method, event, delegate

dotnet_naming_style.pascal_case.capitalization = pascal_case
