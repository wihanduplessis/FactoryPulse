{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "logs/factorypulse-.log",
          "rollingInterval": "Day"
        }
      }
    ]
  },
  "JwtSettings": {
    "Issuer": "FactoryPulse",
    "Audience": "FactoryPulseClients",
    "AccessTokenMinutes": 30
  },
  "SeedAdmin": { "Email": "admin@factorypulse.local" },

  "RateLimiting": {
    "Login": {
      "PermitLimit": 5,
      "WindowSeconds": 60
    }
  },

  "AllowedHosts": "*"
}
